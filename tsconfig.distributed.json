{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "removeComments": false
  },
  "include": [
    "src/distributed/**/*.ts",
    "test/distributed/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
